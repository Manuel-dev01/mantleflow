# --- LLM ---
ANTHROPIC_API_KEY=

# --- Mantle RPC (defaults are public endpoints; override for a paid/dedicated RPC) ---
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# --- Data APIs ---
# Mantlescan now uses the unified Etherscan API V2 (chainid=5000); a free Etherscan key works.
ETHERSCAN_API_KEY=
# DefiLlama is keyless

# Orchestrator model (default claude-opus-4-8)
ORCHESTRATOR_MODEL=claude-opus-4-8

# --- x402 / QuestFlow ---
QUESTFLOW_FACILITATOR_URL=https://facilitator.questflow.ai
QUESTFLOW_FACILITATOR_API_KEY=

# --- ERC-8004 agent wallet (Sepolia-first). NEVER commit a real key. ---
AGENT_PRIVATE_KEY=
