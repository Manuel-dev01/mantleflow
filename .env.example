# --- LLM (orchestrator; OpenAI-compatible API, DeepSeek by default) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# --- Mantle RPC (defaults are public endpoints; override for a paid/dedicated RPC) ---
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# --- Data APIs ---
# Mantlescan via the unified Etherscan API V2 (chainid selects the network); a free Etherscan key works.
ETHERSCAN_API_KEY=
# DefiLlama and GeckoTerminal are keyless.

# --- ERC-8004 agent identity (Sepolia by default; flip to mainnet once an agentId is registered) ---
# AGENT_PRIVATE_KEY drives BOTH the ERC-8004 writer and the x402 self-settle. NEVER commit a real key.
AGENT_PRIVATE_KEY=
AGENT_ID=
ERC8004_NETWORK=sepolia
AGENT_CARD_URL=https://mantleflow.vercel.app/.well-known/agent-card.json

# --- x402 pay-per-query (off by default; the gated endpoint runs free until enabled) ---
X402_ENABLED=false
X402_NETWORK=sepolia
X402_ASSET=
X402_PAY_TO=
X402_PRICE=10000
# Optional QuestFlow facilitator (used instead of self-settle when the key is present).
QUESTFLOW_FACILITATOR_URL=https://facilitator.questflow.ai
QUESTFLOW_API_KEY=
